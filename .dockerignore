# ── git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Bags — distributed separately, mounted as a volume at runtime ─────────────
bags/

# ── Python environments — rebuilt inside the image ────────────────────────────
venv/
__pycache__/
*.pyc

# ── Evaluation outputs — generated at runtime, mounted as a volume ────────────
results/
runs/
logs/

# ── internal dev tooling — not needed in the evaluation image ────────────────
carla_run/
scorecard/

# ── Artefacts ─────────────────────────────────────────────────────────────────
*.npy
*.zip
